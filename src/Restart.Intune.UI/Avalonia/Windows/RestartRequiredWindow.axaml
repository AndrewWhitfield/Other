<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:Restart.Intune.UI.Avalonia.Converters;assembly=Restart.Intune.UI"
        mc:Ignorable="d"
        x:Class="Restart.Intune.UI.Avalonia.Windows.RestartRequiredWindow"
        x:CompileBindings="False"
        Title="Restart Required"
        Width="530" Height="480"
        WindowStartupLocation="Manual"
        SystemDecorations="None"
        Background="Transparent"
        CanResize="False"
        ShowInTaskbar="False"
        Topmost="True">

    <!--
        MAPPING NOTES
        ═══════════════════════════════════════════════════════════════════════════
        WPF Feature                      Avalonia Equivalent                Caveat
        ────────────────────────────────────────────────────────────────────────────
        WindowStyle="None"               SystemDecorations="None"           Exact equivalent.
        AllowsTransparency="True"        Background="Transparent"           No separate flag needed.
        ResizeMode="NoResize"            CanResize="False"                  Exact equivalent.
        DropShadowEffect (15/2/0.3)      BoxShadow="0 2 15 0 #4D000000"    [B6] Near-equivalent.
        Inline style definitions         Local Window.Resources styles      Same scope; no behaviour change.
        ToggleButton IsChecked trigger   :checked pseudo-class selector     Avalonia style equivalent.
        MoreInfoToggleStyle (inline WPF) Theme.axaml key reference          Moved to Theme.axaml for reuse.
        Segoe MDL2 Assets clock icon     Segoe MDL2 Assets (Windows-only)  [B5] Non-Windows: blank.
        FooterLogoSource (ImageSource)   IImage binding                     [B3] WPF type mismatch.
        ConfirmRestartGate (WPF dialog)  await ShowDialog<bool?>()          [B10] In code-behind.
        Later button (no handler in WPF) No Click handler                   Preserved as-is.
        ═══════════════════════════════════════════════════════════════════════════
    -->

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="/Avalonia/Styles/Theme.axaml"/>
            </ResourceDictionary.MergedDictionaries>
            <converters:StringNotEmptyToVisibleConverter x:Key="StringNotEmptyToVisibilityConverter"/>

            <!-- Restart Now Button Theme — matches RestartNowButtonStyle in WPF source -->
            <ControlTheme x:Key="RestartNowButtonStyle" TargetType="Button">
                <Setter Property="Background"  Value="{DynamicResource BrushCBAYellow}"/>
                <Setter Property="Foreground"  Value="{DynamicResource BrushCBABlack}"/>
                <Setter Property="FontSize"    Value="14"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Height"      Value="44"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="20,0">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#Bd">
                    <Setter Property="Background" Value="{DynamicResource BrushCBAAmber}"/>
                </Style>
                <Style Selector="^:pressed /template/ Border#Bd">
                    <Setter Property="Background" Value="#CC9600"/>
                </Style>
            </ControlTheme>

            <!-- Later Button Theme — matches LaterButtonStyle in WPF source -->
            <ControlTheme x:Key="LaterButtonStyle" TargetType="Button">
                <Setter Property="Background"  Value="{DynamicResource BrushCBABlack}"/>
                <Setter Property="Foreground"  Value="{DynamicResource BrushCBAWhite}"/>
                <Setter Property="FontSize"    Value="14"/>
                <Setter Property="FontWeight"  Value="SemiBold"/>
                <Setter Property="Height"      Value="44"/>
                <Setter Property="Cursor"      Value="Hand"/>
                <Setter Property="Template">
                    <ControlTemplate TargetType="Button">
                        <Border Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="20,0">
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter>
                <Style Selector="^:pointerover /template/ Border#Bd">
                    <Setter Property="Background" Value="{DynamicResource BrushCBADarkGrey}"/>
                </Style>
                <Style Selector="^:pressed /template/ Border#Bd">
                    <Setter Property="Background" Value="{DynamicResource BrushCBABlack}"/>
                </Style>
            </ControlTheme>

        </ResourceDictionary>
    </Window.Resources>

    <!-- Main Window Border
         [B6] DropShadowEffect BlurRadius=15, ShadowDepth=2, Opacity=0.3
              → BoxShadow="0 2 15 0 #4D000000" -->
    <Border CornerRadius="10"
            Background="{DynamicResource BrushCBAWhite}"
            BorderBrush="{DynamicResource BrushCBADarkGrey}"
            BorderThickness="2"
            Margin="0,0,0,10"
            BoxShadow="0 2 15 0 #4D000000">

        <Grid RowDefinitions="Auto,*,Auto,Auto">

            <!-- ======================== HEADER ======================== -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BrushCBABlack}"
                    CornerRadius="8,8,0,0"
                    Padding="20,16">
                <Grid ColumnDefinitions="Auto,*">

                    <Grid Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Top">
                        <Ellipse Width="36" Height="36"
                                 Stroke="{DynamicResource BrushCBAYellow}" StrokeThickness="2.5"
                                 Fill="Transparent"/>
                        <!-- &#x21BB; Unicode — no font dependency -->
                        <TextBlock Text="&#x21BB;" FontSize="20"
                                   Foreground="{DynamicResource BrushCBAYellow}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold" Margin="0,-2,0,0"/>
                    </Grid>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Name="TxtTitle"
                                   Text="{Binding TitleText}"
                                   Foreground="{DynamicResource BrushCBAWhite}"
                                   FontSize="18" FontWeight="Bold"/>
                        <TextBlock Name="TxtDeadline"
                                   Text="{Binding DeadlineText}"
                                   Foreground="{DynamicResource BrushCBAMidGrey}"
                                   FontSize="12" Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ======================== CONTENT ======================== -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Disabled"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="24,20,24,10">

                    <!-- Alert Banner -->
                    <Border Background="{DynamicResource BrushCBAAmberLight}"
                            BorderBrush="{DynamicResource BrushCBAAmber}"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="16,14"
                            Margin="0,0,0,20">
                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">

                            <TextBlock Grid.Row="0" Grid.Column="0"
                                       Text="⚠" FontSize="18"
                                       Foreground="{DynamicResource BrushCBAAmber}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,6"/>
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Text="Action Required"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource BrushCBABlack}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,6"/>

                            <StackPanel Grid.Row="1" Grid.Column="1"
                                        Orientation="Horizontal">
                                <!-- [B5] Segoe MDL2 Assets clock icon — Windows-only -->
                                <TextBlock Text="&#xE916;" FontSize="13"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{DynamicResource BrushCBADarkGrey}"
                                           VerticalAlignment="Center"
                                           Margin="0,0,6,0"/>
                                <TextBlock Name="TxtTimeRemaining"
                                           Text="{Binding TimeRemainingText}"
                                           FontSize="13"
                                           Foreground="{DynamicResource BrushCBABlack}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Description Paragraph 1 -->
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource BrushCBABlack}"
                               LineHeight="20"
                               Margin="0,0,0,14">
                        Your computer needs to restart to complete important updates.
                    </TextBlock>

                    <!-- Description Paragraph 2 -->
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource BrushCBABlack}"
                               LineHeight="20"
                               Margin="0,0,0,20">
                        Please save your work and restart as soon as possible. If you don't restart by the deadline, your computer will restart automatically.
                    </TextBlock>

                    <!-- Tip Paragraph -->
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="{DynamicResource BrushCBADarkGrey}"
                               LineHeight="20"
                               Margin="0,0,0,0">
                        <Run FontWeight="Bold" Text="Tip:"/>
                        <Run Text=" Shut down or restart your device regularly to avoid this notification."/>
                    </TextBlock>

                    <!-- More Information Expander
                         WPF: MoreInfoToggleStyle defined inline in Window.Resources
                         Avalonia: style moved to Theme.axaml; same key referenced here -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,12,0,0">
                        <ToggleButton Name="MoreInfoToggle"
                                      Theme="{StaticResource MoreInfoToggleStyle}"
                                      IsChecked="{Binding IsShowingUpdateDetails, Mode=TwoWay}"/>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>

            <!-- ======================== BUTTONS ======================== -->
            <Grid Grid.Row="2" Margin="24,0,24,12" ColumnDefinitions="*,16,*">

                <Button Name="BtnRestartNow"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Content="Restart Now"
                        Theme="{StaticResource RestartNowButtonStyle}"
                        Click="BtnRestartNow_Click"
                        AutomationProperties.Name="Restart Now — opens confirmation dialog"/>

                <Button Name="BtnLater"
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Content="Remind Me Later"
                        Theme="{StaticResource LaterButtonStyle}"
                        Click="BtnLater_Click"
                        AutomationProperties.Name="Remind Me Later — closes this notification"/>
            </Grid>

            <!-- ======================== FOOTER ======================== -->
            <Border Grid.Row="3"
                    Background="{DynamicResource BrushCBALightGrey}"
                    CornerRadius="0,0,10,10"
                    Padding="24,10">
                <Grid ColumnDefinitions="Auto,*,Auto">

                    <Border Grid.Column="0"
                            Width="32" Height="32" CornerRadius="16"
                            Background="{DynamicResource BrushCBABlack}"
                            Margin="0,0,10,0">
                        <!--
                            [B3] FooterLogoSource is System.Windows.Media.ImageSource.
                            Will not bind until ViewModel uses IImage.
                        -->
                        <Image Name="BrandLogo"
                               Source="{Binding FooterLogoSource}"
                               Width="31" Height="17"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FooterText}"
                                   Theme="{StaticResource TextCaption}"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushCBABlack}"/>
                        <TextBlock Text="CBA Technology"
                                   Theme="{StaticResource TextCaption}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Name="TxtBuildVersion"
                                   Text="{Binding BuildVersion}"
                                   Theme="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"
                                   AutomationProperties.Name="Application build version"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
